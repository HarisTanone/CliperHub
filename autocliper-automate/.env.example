# ═══════════════════════════════════════════════════════════════════════════
# AutoCliper Automate - Environment Configuration
# Copy file ini ke .env dan sesuaikan nilainya
# ═══════════════════════════════════════════════════════════════════════════

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | staging | production

# ─── Database (sama dengan autocliper-v2) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=autocliper

# ─── Encryption ──────────────────────────────────────────────────────────────
# Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ─── Redis (untuk job queue) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ─── Proxy Default (opsional) ────────────────────────────────────────────────
# Format: http://user:pass@host:port atau socks5://user:pass@host:port
DEFAULT_PROXY_URL=

# ─── Rate Limiting (TikTok Level) ────────────────────────────────────────────
# Minimum interval antar upload (dalam detik) - untuk menghindari deteksi bot
MIN_UPLOAD_INTERVAL_SECONDS=3600
SESSION_WARM_UP_SECONDS=45
MAX_CONCURRENT_BROWSERS=2
COOL_DOWN_AFTER_ERROR_SECONDS=1800

# ─── Queue Behavior ──────────────────────────────────────────────────────────
# Strategy when all accounts hit daily limit: hold | redistribute | notify_and_hold
DAILY_LIMIT_STRATEGY=hold

# ─── Playwright Configuration ────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
# Slow motion dalam ms (untuk debugging, set ke 0 untuk production)
PLAYWRIGHT_SLOW_MO=50
# Timeout dalam ms
PLAYWRIGHT_TIMEOUT=30000
# Download browser otomatis jika belum ada
PLAYWRIGHT_DOWNLOAD_BROWSERS=true

# ─── Session Configuration ───────────────────────────────────────────────────
# Validasi session setiap X jam
SESSION_VALIDATION_INTERVAL_HOURS=6
# Session dianggap expired setelah X hari
SESSION_MAX_AGE_DAYS=7

# ─── Upload Configuration ────────────────────────────────────────────────────
# Max retry untuk upload yang gagal
MAX_UPLOAD_RETRIES=3
# Delay antar retry dalam detik
RETRY_DELAY_SECONDS=300
# Max file size dalam MB
MAX_VIDEO_SIZE_MB=500

# ─── 2FA / Verification ──────────────────────────────────────────────────────
VERIFICATION_TIMEOUT_SECONDS=600
VERIFICATION_NOTIFY_TELEGRAM=true
VERIFICATION_NOTIFY_EMAIL=true
VERIFICATION_NOTIFY_WEBSOCKET=true
VERIFICATION_ALLOW_REMOTE_BROWSER=true
VERIFICATION_AUTO_RETRY_AFTER_HOURS=6

# ─── Alerting - Telegram ─────────────────────────────────────────────────────
TELEGRAM_ALERT_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
# Alert levels: critical,warning,info (comma separated)
TELEGRAM_NOTIFY_ON=critical,warning

# ─── Alerting - Email ────────────────────────────────────────────────────────
EMAIL_ALERT_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_RECIPIENTS=admin@example.com
EMAIL_NOTIFY_ON=critical

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=automate.log
LOG_FORMAT=json  # json | text
LOG_ROTATION=daily  # daily | size
LOG_MAX_SIZE_MB=100
LOG_RETENTION_DAYS=7

# ─── Screenshots ─────────────────────────────────────────────────────────────
SAVE_ERROR_SCREENSHOTS=true
SCREENSHOT_DIR=./tmp/screenshots
SCREENSHOT_RETENTION_DAYS=7

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
# Secret key untuk JWT (HARUS SAMA dengan autocliper-v2 untuk SSO)
SECRET_KEY=your-secret-key-same-as-autocliper-v2

# ─── API Rate Limiting ───────────────────────────────────────────────────────
RATE_LIMIT_ACCOUNTS_PER_HOUR=10
RATE_LIMIT_UPLOADS_PER_HOUR=30
RATE_LIMIT_GENERAL_PER_MINUTE=100

# ─── Integration dengan AutoCliper v2 ────────────────────────────────────────
AUTOCLIPER_V2_URL=http://localhost:8000
# Path ke folder output autocliper-v2
AUTOCLIPER_OUTPUT_DIR=../autocliper-v2/tmp/output

# ─── Remote Browser (Development) ────────────────────────────────────────────
# Untuk debugging dengan PLAYWRIGHT_HEADLESS=false di server
VNC_ENABLED=false
VNC_PORT=5900
VNC_PASSWORD=secret
NOVNC_PORT=6080

# ─── CAPTCHA Solving ─────────────────────────────────────────────────────────
CAPTCHA_SOLVER_ENABLED=true
# Service: 2captcha | anti-captcha | capsolver
CAPTCHA_SOLVER_SERVICE=capsolver
CAPTCHA_SOLVER_API_KEY=your-captcha-api-key
CAPTCHA_SOLVER_TIMEOUT_SECONDS=120
CAPTCHA_SOLVER_MAX_RETRIES=3
# Fallback to manual if solver fails
CAPTCHA_FALLBACK_TO_MANUAL=true

# ─── Account Warm-up ─────────────────────────────────────────────────────────
WARMUP_ENABLED=true
# Sessions per day during warmup
WARMUP_SESSIONS_PER_DAY=4
# Min/max session duration in minutes
WARMUP_SESSION_MIN_MINUTES=5
WARMUP_SESSION_MAX_MINUTES=15
# Auto-advance phases based on days
WARMUP_AUTO_ADVANCE=true

# ─── Analytics ───────────────────────────────────────────────────────────────
# Fetch video performance metrics every X hours
ANALYTICS_FETCH_INTERVAL_HOURS=6
# Trending hashtags refresh interval
TRENDING_HASHTAGS_REFRESH_HOURS=12
# Country code for trending hashtags
TRENDING_HASHTAGS_COUNTRY=ID
