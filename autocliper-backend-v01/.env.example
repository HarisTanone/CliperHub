# Database
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/autoclip_v1

# Google Drive
GOOGLE_DRIVE_CREDENTIALS_PATH=credentials.json
GOOGLE_DRIVE_PARENT_FOLDER_ID=YouTubeClipGenerator

# Limits
MAX_VIDEO_DURATION=3600
DOWNLOAD_TIMEOUT=600
EXTRACT_TIMEOUT=120
UPLOAD_TIMEOUT=120
POLLING_INTERVAL=15
POLLING_TIMEOUT=1800

# Rendering
MAX_RENDER_WORKERS=3
MIN_CLIP_DURATION=5.0
OUTPUT_DIR=tmp/output
DOWNLOAD_DIR=tmp/downloads

# Cleanup
CLEANUP_MAX_AGE_DAYS=7

# Gemini (for Colab reference)
GEMINI_API_KEY=
