{
  "name": "autocliper-remotion",
  "version": "1.0.0",
  "description": "Remotion overlay renderer for AutoCliper video compositions",
  "private": true,
  "scripts": {
    "start": "npx remotion studio",
    "build": "npx remotion bundle --out-dir ./build",
    "render": "npx remotion render ClipComposition",
    "benchmark": "npx ts-node --project scripts/tsconfig.json scripts/benchmark.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@remotion/cli": "4.0.242",
    "@remotion/google-fonts": "4.0.242",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.242"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "jsdom": "^29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
