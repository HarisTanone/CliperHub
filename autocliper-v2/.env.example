# Database Configuration
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/autocliper

# JWT Authentication (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080
JWT_REFRESH_SECRET_KEY=your_refresh_secret_key_here

# Gemini AI API Key (Required)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 Key (Required)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Whisper Configuration (Optional - for subtitle generation)
# Option 1: whisper.cpp binary path
WHISPER_BINARY=whisper-cpp
WHISPER_MODEL_PATH=./models/ggml-medium.bin

# Output Directory
OUTPUT_DIR=./tmp/output

# Chunked Analysis (Multi-Pass AI)
# Set to "true" to enable transcript chunking + multi-pass Gemini analysis
# Recommended for videos >10 minutes — more accurate clip detection
USE_CHUNKED_ANALYSIS=false
# Model override for chunked analysis (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Local AI Fallback (Mistral-Nemo via Ollama)
# Auto-fallback when Gemini API fails (429, 503, quota exceeded)
# Requires: ollama installed + model pulled
# Recommended: mistral-nemo:12b (7GB, fast, excellent JSON compliance)
OLLAMA_URL=http://localhost:11434
QWEN_MODEL=mistral-nemo:12b

# Hybrid AI Pipeline
# Set to "true" to use Qwen for Pass #1 (candidate detection) and Gemini for Pass #2 (hooks)
# Benefits: Free Pass #1, reliable (no API quota issues), same final quality
# Tradeoff: Pass #1 ~6 min (vs ~6 sec with Gemini), but Pass #2 still fast (~3 sec)
USE_QWEN_FOR_PASS1=false
# Provider-specific timeouts (seconds)
QWEN_TIMEOUT=300
GEMINI_TIMEOUT=60

# Redis Configuration (Recommended for production — crash-safe queue)
# If not set, falls back to in-memory queue (jobs lost on crash)
REDIS_URL=redis://localhost:6379/0
